{
  "name": "wial-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9 <23"
  },
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "dev:next": "next dev",
    "build": "node scripts/reliable-build.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "content:sync": "node scripts/sync-content-artifacts.mjs",
    "seed:coaches": "tsx scripts/seed-coaches.ts",
    "backfill:credly": "tsx scripts/backfill-credly-badges.ts",
    "dolt:setup": "bash ops/dolt/setup.sh",
    "dolt:status": "cd ops/dolt/repo && dolt status",
    "dolt:log": "cd ops/dolt/repo && dolt log --oneline"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "@tiptap/extension-image": "^3.21.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "next": "^15.5.14",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanitize-html": "^2.17.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.14",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
